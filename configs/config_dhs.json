{
  "model": {
    "name": "zhihan1996/DNA_bert_6",
    "tuning": -2,
    "hidden_factor": 1,
    "dropout": 0.2,
    "pooling": "cls"
  },

  "data": {
    "type": "dhs",
    "input_file": "data/filtered_dataset.txt",

    "batch_size": 8,
    "num_workers": 2,

    "split_mode": "chromosome",

    "train_chroms": ["chr1", "chr2", "chr3", "chr4", "chr5", "chr6", "chr7", "chr8"],
    "val_chroms": ["chr9", "chr10"],
    "test_chroms": ["chr11", "chr12"],

    "max_len": 256,
    "kmer_size": 6,
    "precompute_kmers": true
  },

  "training": {
    "max_epochs": 10,
    "precision": "16-mixed",
    "check_val_every_n_epoch": 2,
    "seed": 42,
    "loss": "cross_entropy",
    "optimizer": "adamw",
    "lr": 2e-5,
    "metric_average": "macro"
  },

  "output": {
    "dir": "outputs/dhs"
  }
}